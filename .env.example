# Required: Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_key_here

# Stronger/slower model for better deal decisions.
# If your account cannot access this model, try gemini-2.5-flash or gemini-1.5-flash.
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMPERATURE=0.2
GEMINI_THINKING_BUDGET=8192

# Gmail/IMAP for Leboncoin saved-search alert emails
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_gmail_app_password
IMAP_FOLDER=INBOX
LBC_EMAIL_FILTER=leboncoin

# Telegram notifications and buttons
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk controls
MAX_TOTAL_EUR=120
MIN_BUY_READY_SCORE=88
MIN_CONFIDENCE=0.72
DAILY_PURCHASE_LIMIT_EUR=250
MONITOR_INTERVAL_SECONDS=60

# Playwright browser profile for Leboncoin login, seller messages, and guided checkout.
# The first time, the bot may open a browser. Log in manually if Leboncoin asks.
PURCHASE_MODE=guided
PLAYWRIGHT_USER_DATA_DIR=.browser-profile
