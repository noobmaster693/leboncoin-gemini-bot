# Required: Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_key_here

# Flash is the practical default. Pro may require billing/quota.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-1.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_THINKING_BUDGET=4096

# Gmail/IMAP for Leboncoin saved-search alert emails
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_gmail_app_password
IMAP_FOLDER=INBOX
LBC_EMAIL_FILTER=leboncoin

# Ignore unread Leboncoin emails older than this many days.
MAX_EMAIL_AGE_DAYS=3

# How many embedded listing cards/links to process from one digest email.
MAX_LISTING_LINKS_PER_EMAIL=25

# Use BODY.PEEK so reading does not mark emails read automatically.
# For normal use true is best; for testing same unread email repeatedly, set false.
MARK_EMAILS_SEEN_AFTER_PARSE=true
REPROCESS_EXISTING_LISTINGS=false

# Telegram notifications and buttons
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk controls
MAX_TOTAL_EUR=120
MIN_BUY_READY_SCORE=88
MIN_CONFIDENCE=0.72
DAILY_PURCHASE_LIMIT_EUR=250
MONITOR_INTERVAL_SECONDS=60

# Recommended default: false.
# The bot analyzes the embedded email card first, instead of opening every Leboncoin page.
# This greatly reduces CAPTCHA/robot checks. Set true only if you accept more page loads.
FETCH_LISTING_DETAILS=false

# Playwright browser profile for Leboncoin login, seller messages, and guided checkout.
# The browser still opens for Ask seller / checkout / manual actions.
PURCHASE_MODE=guided
PLAYWRIGHT_USER_DATA_DIR=.browser-profile
