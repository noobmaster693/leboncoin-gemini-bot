# Required: Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# Gmail/IMAP for Leboncoin saved-search alert emails
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_gmail_app_password
IMAP_FOLDER=INBOX
LBC_EMAIL_FILTER=leboncoin

# Optional Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk controls
MAX_TOTAL_EUR=120
MIN_BUY_READY_SCORE=88
MIN_CONFIDENCE=0.72
DAILY_PURCHASE_LIMIT_EUR=250

# Playwright guided purchase mode
# guided = opens a visible browser after your confirmation; it does not bypass CAPTCHA/2FA.
PURCHASE_MODE=guided
PLAYWRIGHT_USER_DATA_DIR=.browser-profile
